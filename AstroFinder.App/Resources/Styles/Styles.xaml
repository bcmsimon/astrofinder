<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource ColorPrimary}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource ColorOnSurface}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{DynamicResource ColorSurface}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource ColorSurface}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource ColorOnSurface}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource ColorOnSurface}" />
        <Setter Property="Shell.UnselectedColor" Value="{DynamicResource ColorOnSurfaceVariant}" />
    </Style>

</ResourceDictionary>
