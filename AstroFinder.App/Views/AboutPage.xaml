<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AstroFinder.App.Views.AboutPage"
             Title="About">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource ColorSurface}">

        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource ColorSurfaceAlt}">

            <Label Grid.Column="1"
                   Text="About"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   FontAttributes="Bold"
                   FontSize="20"
                   TextColor="{DynamicResource ColorPrimary}" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="12">
                <Label Text="AstroFinder"
                       FontAttributes="Bold"
                       FontSize="24"
                       TextColor="{DynamicResource ColorPrimary}"
                       HorizontalTextAlignment="Center"
                       Margin="0,32,0,0" />

                <Label Text="Version 1.0"
                       FontSize="14"
                       TextColor="{DynamicResource ColorOnSurfaceVariant}"
                       HorizontalTextAlignment="Center" />

                <Label Text="Astrophotography sky navigation and framing assistant. Locate deep-sky objects using star-hopping techniques and precise coordinate offsets."
                       FontSize="13"
                       TextColor="{DynamicResource ColorOnSurfaceVariant}"
                       HorizontalTextAlignment="Center"
                       Margin="16,8" />

                <Label Text="Part of the AstroApps ecosystem."
                       FontSize="12"
                       TextColor="{DynamicResource ColorOnSurfaceVariant}"
                       HorizontalTextAlignment="Center"
                       Margin="0,16,0,0" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
