<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AstroFinder.App.Views.SettingsPage"
             Title="Settings">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource ColorSurface}">

        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource ColorSurfaceAlt}">

            <Label Grid.Column="1"
                   Text="Settings"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   FontAttributes="Bold"
                   FontSize="20"
                   TextColor="{DynamicResource ColorPrimary}" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="12">
                <Label Text="Settings will be available here."
                       FontSize="14"
                       TextColor="{DynamicResource ColorOnSurfaceVariant}"
                       HorizontalTextAlignment="Center"
                       Margin="0,32,0,0" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
