<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AstroFinder.App.Views.SettingsPage"
             Title="Sky orientation"
             BackgroundColor="{DynamicResource ColorBackground}">

    <Grid RowDefinitions="Auto,*" RowSpacing="12" Padding="16">

        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource ColorSurface}"
                Stroke="{DynamicResource ColorBorder}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                Padding="16,12">
            <Label Text="Sky orientation"
                   FontAttributes="Bold"
                   FontSize="20"
                   TextColor="{DynamicResource ColorPrimary}" />
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12">

                <!-- Location orientation card -->
                <Border BackgroundColor="{DynamicResource ColorSurface}"
                        Stroke="{DynamicResource ColorBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="16">
                      <VerticalStackLayout Spacing="12">
                       <Label Text="Mount selection"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="{DynamicResource ColorTextPrimary}" />

                       <Label Text="Choose the mount AstroFinder should use for RA/Dec guidance and Manual Goto. This selection is persisted and reused on launch."
                           FontSize="13"
                           TextColor="{DynamicResource ColorTextSecondary}"
                           LineBreakMode="WordWrap" />

                       <Label Text="{Binding SelectedMountText}"
                           FontSize="13"
                           TextColor="{DynamicResource ColorTextPrimary}" />

                       <Button Text="Select mount"
                            BackgroundColor="{DynamicResource ColorPrimary}"
                            TextColor="{DynamicResource ColorTextInverse}"
                            Clicked="OnSelectMountClicked" />
                      </VerticalStackLayout>
                  </Border>

                  <Border BackgroundColor="{DynamicResource ColorSurface}"
                       Stroke="{DynamicResource ColorBorder}"
                       StrokeThickness="1"
                       StrokeShape="RoundRectangle 14"
                       Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Use my location for sky-aligned maps"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{DynamicResource ColorTextPrimary}" />
                                <Label Text="When enabled, AstroFinder uses your location and the current time to rotate the star hop chart to match the sky you are looking at."
                                       FontSize="13"
                                       TextColor="{DynamicResource ColorTextSecondary}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <Switch Grid.Column="1"
                                    x:Name="LocationToggle"
                                    IsToggled="{Binding UseLocationOrientation}"
                                    OnColor="{DynamicResource ColorPrimary}"
                                    Toggled="OnLocationToggleChanged"
                                    VerticalOptions="Center" />
                        </Grid>

                        <ActivityIndicator IsVisible="{Binding IsBusy}"
                                           IsRunning="{Binding IsBusy}"
                                           Color="{DynamicResource ColorPrimary}" />

                        <Label Text="{Binding StatusText}"
                               FontSize="12"
                               TextColor="{DynamicResource ColorTextSecondary}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{DynamicResource ColorSurface}"
                        Stroke="{DynamicResource ColorBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Flip sky-map rotation direction"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="{DynamicResource ColorTextPrimary}" />
                            <Label Text="Use this if the sky-oriented star hop map appears mirrored or rotates opposite to the real sky. On = use -q. Off = use q."
                                   FontSize="13"
                                   TextColor="{DynamicResource ColorTextSecondary}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Switch Grid.Column="1"
                                x:Name="ParallacticDirectionToggle"
                                IsToggled="{Binding InvertParallacticAngleForDisplay}"
                                OnColor="{DynamicResource ColorPrimary}"
                                Toggled="OnParallacticDirectionToggleChanged"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- AR camera card -->
                <Border BackgroundColor="{DynamicResource ColorSurface}"
                        Stroke="{DynamicResource ColorBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Use camera for AR sky view"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{DynamicResource ColorTextPrimary}" />
                                <Label Text="When enabled, AstroFinder may use your phone&#x2019;s camera as a live background for the star-hop overlay. Point your phone at the sky and the anchor star, hop path, and target are drawn over the live camera view. The camera feed is never recorded or transmitted."
                                       FontSize="13"
                                       TextColor="{DynamicResource ColorTextSecondary}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <Switch Grid.Column="1"
                                    x:Name="ArCameraToggle"
                                    IsToggled="{Binding UseArCamera}"
                                    OnColor="{DynamicResource ColorPrimary}"
                                    Toggled="OnArCameraToggleChanged"
                                    VerticalOptions="Center" />
                        </Grid>

                        <Label Text="{Binding ArStatusText}"
                               FontSize="12"
                               TextColor="{DynamicResource ColorTextSecondary}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- AR debug HUD card -->
                <Border BackgroundColor="{DynamicResource ColorSurface}"
                        Stroke="{DynamicResource ColorBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Show AR debug HUD"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="{DynamicResource ColorTextPrimary}" />
                            <Label Text="Shows a diagnostic overlay in the AR view with heading, pitch, and map overlay status."
                                   FontSize="13"
                                   TextColor="{DynamicResource ColorTextSecondary}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Switch Grid.Column="1"
                                x:Name="ArDebugHudToggle"
                                IsToggled="{Binding ShowArDebugHud}"
                                OnColor="{DynamicResource ColorPrimary}"
                                Toggled="OnArDebugHudToggleChanged"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
