<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AstroFinder.App.Controls"
             x:Class="AstroFinder.App.Views.ArStarHopPage"
             Title="AR Stars"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid>

        <!-- CAMERA PREVIEW LAYER: ARCore camera background rendered by native GLSurfaceView -->
        <controls:ArCameraView x:Name="ArCamera"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill" />

        <!-- Optional simulated night-vision filter -->
        <BoxView x:Name="NightFilterOverlay"
                 IsVisible="False"
                 InputTransparent="True"
                 Color="#DD140000"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- OVERLAY LAYER: transparent canvas drawn on top of the camera feed. -->
        <GraphicsView x:Name="OverlayView"
                      BackgroundColor="Transparent"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      InputTransparent="True" />

        <!-- HUD: top bar with close / heading / calibrate -->
          <Grid VerticalOptions="Start"
                  HorizontalOptions="Fill"
                  Padding="12,48,12,12"
                  RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8"
                          RowSpacing="6">

            <Button Grid.Column="0"
                    Text="Close"
                    BackgroundColor="#80000000"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="10"
                    Padding="14,8"
                    Clicked="OnCloseClicked" />

            <Button Grid.Column="1"
                    x:Name="NightModeButton"
                    Text="Night AR"
                    BackgroundColor="#80000000"
                    TextColor="White"
                    FontSize="13"
                    CornerRadius="10"
                    Padding="12,8"
                    Clicked="OnNightModeClicked" />

            <Button Grid.Column="2"
                    Text="Calibrate"
                    BackgroundColor="#80000000"
                    TextColor="White"
                    FontSize="13"
                    CornerRadius="10"
                    Padding="12,8"
                    Clicked="OnCalibrateClicked" />

            <Label Grid.Row="1"
                   Grid.ColumnSpan="4"
                   x:Name="HeadingLabel"
                   Text="—"
                   TextColor="#CCFFFFFF"
                   FontSize="12"
                   LineBreakMode="NoWrap"
                   MaxLines="1"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />

            <Label Grid.Row="2"
                   Grid.ColumnSpan="4"
                   x:Name="DiagHudLabel"
                   Text=""
                   TextColor="#B8000000"
                   BackgroundColor="#60FFFFFF"
                   FontSize="9"
                   FontFamily="monospace"
                   LineBreakMode="WordWrap"
                   MaxLines="14"
                   Padding="6,4"
                   HorizontalTextAlignment="Start"
                   VerticalTextAlignment="Start" />

        </Grid>

        <!-- Centre reticle: a faint crosshair to show where the phone is pointing. -->
        <BoxView WidthRequest="1"
                 HeightRequest="40"
                 Color="#33FFFFFF"
                 HorizontalOptions="Center"
                 VerticalOptions="Center" />
        <BoxView WidthRequest="40"
                 HeightRequest="1"
                 Color="#33FFFFFF"
                 HorizontalOptions="Center"
                 VerticalOptions="Center" />

        <!-- Status banner: shown when sensors or location are unavailable. -->
        <Border x:Name="StatusBanner"
                IsVisible="False"
                BackgroundColor="#CC000000"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12"
                Padding="20,14"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Label x:Name="StatusLabel"
                   Text=""
                   TextColor="White"
                   FontSize="14"
                   HorizontalTextAlignment="Center" />
        </Border>

        <!-- Calibration hint: auto-dismissed after a few seconds. -->
        <Border x:Name="CalibrationHint"
                IsVisible="False"
                BackgroundColor="#CC1A2E44"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0"
                Padding="16,12"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="0,0,0,40">
            <Label Text="Move the phone slowly in a figure-eight to improve compass accuracy."
                   TextColor="White"
                   FontSize="13"
                   HorizontalTextAlignment="Center" />
        </Border>

    </Grid>

</ContentPage>
