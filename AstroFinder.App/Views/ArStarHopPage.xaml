<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AstroFinder.App.Controls"
             x:Class="AstroFinder.App.Views.ArStarHopPage"
              Title="AR Diagnostic"
             Shell.NavBarIsVisible="False"
              BackgroundColor="{DynamicResource ColorBackground}">

    <Grid>
        <controls:ArCameraView x:Name="ArCamera"
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill" />

         <Grid VerticalOptions="Start"
                HorizontalOptions="Fill"
                Padding="12,48,12,12"
                RowDefinitions="Auto,Auto"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="12"
                RowSpacing="12">

            <Button Grid.Column="0"
                    Text="Close"
                      BackgroundColor="{DynamicResource ColorPrimary}"
                      TextColor="{DynamicResource ColorTextInverse}"
                    FontSize="14"
                    CornerRadius="10"
                    Padding="14,8"
                    Clicked="OnCloseClicked" />

             <Border Grid.Column="1"
                      BackgroundColor="{DynamicResource ColorSurface}"
                      Stroke="{DynamicResource ColorBorder}"
                      StrokeShape="RoundRectangle 14"
                      StrokeThickness="1"
                      Padding="12"
                      Opacity="0.96">
                  <VerticalStackLayout Spacing="6">
                      <Label Text="AR anchor diagnostic"
                              FontSize="14"
                              FontAttributes="Bold"
                              TextColor="{DynamicResource ColorTextPrimary}" />
                      <Label Text="Only camera passthrough, one world marker, and this HUD are left enabled so anchor drift is easier to isolate."
                              FontSize="12"
                              TextColor="{DynamicResource ColorTextSecondary}" />
                  </VerticalStackLayout>
             </Border>

             <Border Grid.Row="1"
                      Grid.ColumnSpan="2"
                      BackgroundColor="{DynamicResource ColorSurface}"
                      Stroke="{DynamicResource ColorBorder}"
                      StrokeShape="RoundRectangle 14"
                      StrokeThickness="1"
                      Padding="12"
                      Opacity="0.96">
                  <VerticalStackLayout Spacing="4">
                      <Label x:Name="HudPlatformLabel"
                              Text="Platform: pending"
                              FontSize="12"
                              TextColor="{DynamicResource ColorTextPrimary}" />
                      <Label x:Name="HudSessionLabel"
                              Text="Session initialized: no"
                              FontSize="12"
                              TextColor="{DynamicResource ColorTextPrimary}" />
                      <Label x:Name="HudTrackingLabel"
                              Text="Tracking state: waiting"
                              FontSize="12"
                              TextColor="{DynamicResource ColorTextPrimary}" />
                      <Label x:Name="HudAnchorCountLabel"
                              Text="Anchor placed count: 0"
                              FontSize="12"
                              TextColor="{DynamicResource ColorTextPrimary}" />
                      <Label x:Name="HudMarkerPoseLabel"
                              Text="Marker pose: not placed"
                              FontSize="12"
                              LineBreakMode="WordWrap"
                              TextColor="{DynamicResource ColorTextSecondary}" />
                      <Label x:Name="HudStatusLabel"
                              Text="Status: waiting for AR session"
                              FontSize="12"
                              LineBreakMode="WordWrap"
                              TextColor="{DynamicResource ColorAccent}" />
                  </VerticalStackLayout>
             </Border>
        </Grid>
    </Grid>

</ContentPage>
