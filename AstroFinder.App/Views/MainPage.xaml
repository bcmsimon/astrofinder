<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:AstroApps.Maui.UIKit.Controls;assembly=AstroApps.Maui.UIKit"
             x:Class="AstroFinder.App.Views.MainPage"
             Title="AstroFinder">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource ColorSurface}">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource ColorSurfaceAlt}">

            <Label Grid.Column="0"
                   Text="AstroFinder"
                   FontAttributes="Bold"
                   FontSize="20"
                   VerticalTextAlignment="Center"
                   TextColor="{DynamicResource ColorPrimary}" />

            <ui:AppIconButton Grid.Column="2"
                              IconGlyph="&#x2699;"
                              Variant="Surface"
                              Size="40"
                              Command="{Binding NavigateToSettingsCommand}" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="16">

                <Label Text="Select a target to begin"
                       FontSize="16"
                       TextColor="{DynamicResource ColorOnSurface}"
                       HorizontalTextAlignment="Center"
                       Margin="0,32,0,0" />

                <Label Text="AstroFinder helps you locate deep-sky objects using star-hopping techniques and precise coordinate offsets."
                       FontSize="13"
                       TextColor="{DynamicResource ColorOnSurfaceVariant}"
                       HorizontalTextAlignment="Center"
                       Margin="16,8" />

                <!-- Target search placeholder -->
                <Frame Padding="16"
                       CornerRadius="12"
                       BackgroundColor="{DynamicResource ColorSurfaceAlt}"
                       BorderColor="{DynamicResource ColorOutline}"
                       HasShadow="False"
                       Margin="0,16,0,0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Target Search"
                               FontAttributes="Bold"
                               FontSize="15"
                               TextColor="{DynamicResource ColorOnSurface}" />
                        <Label Text="Search for Messier, NGC, or named deep-sky objects"
                               FontSize="12"
                               TextColor="{DynamicResource ColorOnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Quick targets placeholder -->
                <Frame Padding="16"
                       CornerRadius="12"
                       BackgroundColor="{DynamicResource ColorSurfaceAlt}"
                       BorderColor="{DynamicResource ColorOutline}"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Popular Targets"
                               FontAttributes="Bold"
                               FontSize="15"
                               TextColor="{DynamicResource ColorOnSurface}" />
                        <Label Text="M31 - Andromeda Galaxy"
                               FontSize="13"
                               TextColor="{DynamicResource ColorOnSurfaceVariant}" />
                        <Label Text="M42 - Orion Nebula"
                               FontSize="13"
                               TextColor="{DynamicResource ColorOnSurfaceVariant}" />
                        <Label Text="M81 - Bode's Galaxy"
                               FontSize="13"
                               TextColor="{DynamicResource ColorOnSurfaceVariant}" />
                        <Label Text="M45 - Pleiades"
                               FontSize="13"
                               TextColor="{DynamicResource ColorOnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
