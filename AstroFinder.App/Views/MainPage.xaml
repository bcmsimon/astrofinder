<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:AstroApps.Maui.UIKit.Controls;assembly=AstroApps.Maui.UIKit"
             x:Class="AstroFinder.App.Views.MainPage"
             x:Name="Root"
             Title="AstroFinder">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource ColorBackground}">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource ColorSurface}">

            <Label Grid.Column="0"
                   Text="AstroFinder"
                   FontAttributes="Bold"
                   FontSize="20"
                   VerticalTextAlignment="Center"
                   TextColor="{DynamicResource ColorPrimary}" />

            <ui:AppIconButton Grid.Column="2"
                              IconGlyph="⚙"
                              Variant="Outlined"
                              Size="40"
                              Command="{Binding Source={x:Reference Root}, Path=OpenSettingsCommand}" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="12">

                <!-- Target Section -->
                <ui:SectionHeader Title="Target" />

                <!-- Selected target chip -->
                <Border IsVisible="{Binding HasSelectedTarget}"
                        BackgroundColor="{DynamicResource ColorPrimary}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,8"
                        HorizontalOptions="Start">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="{Binding SelectedTargetText}"
                               TextColor="{DynamicResource ColorTextInverse}"
                               FontSize="14"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="{DynamicResource ColorTextInverse}"
                               FontSize="14"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearTargetCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Target search -->
                <Border IsVisible="{Binding HasSelectedTarget, Converter={StaticResource InvertBool}}"
                        Style="{DynamicResource CardBorder}"
                        Padding="12,0">
                    <Entry x:Name="TargetSearchBar"
                           Placeholder="Search targets (M31, NGC 7000, Orion...)"
                           Text="{Binding TargetSearchText, Mode=TwoWay}"
                           TextChanged="OnTargetSearchTextChanged"
                           PlaceholderColor="{DynamicResource ColorTextMuted}"
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Search"
                           VerticalOptions="Center" />
                </Border>

                <!-- Target results -->
                <CollectionView IsVisible="{Binding IsTargetListVisible}"
                                ItemsSource="{Binding FilteredTargets}"
                                SelectionMode="Single"
                                SelectionChanged="OnTargetSelected"
                                MaximumHeightRequest="200">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{DynamicResource ColorSurface}"
                                    Stroke="{DynamicResource ColorBorder}"
                                    StrokeThickness="1"
                                    Padding="12,10"
                                    StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding DisplayName}"
                                           TextColor="{DynamicResource ColorTextPrimary}"
                                           FontSize="14" />
                                    <Label Text="{Binding Category}"
                                           TextColor="{DynamicResource ColorTextSecondary}"
                                           FontSize="11" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Reference Star Section -->
                <ui:SectionHeader Title="Reference Star" Margin="0,8,0,0" />

                <!-- Selected star chip -->
                <Border IsVisible="{Binding HasSelectedStar}"
                        BackgroundColor="{DynamicResource ColorSecondary}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,8"
                        HorizontalOptions="Start">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="{Binding SelectedStarText}"
                               TextColor="{DynamicResource ColorTextInverse}"
                               FontSize="14"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="{DynamicResource ColorTextInverse}"
                               FontSize="14"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearStarCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Star search -->
                <Border IsVisible="{Binding HasSelectedStar, Converter={StaticResource InvertBool}}"
                        Style="{DynamicResource CardBorder}"
                        Padding="12,0">
                    <Entry x:Name="StarSearchBar"
                           Placeholder="Search reference stars (Vega, Polaris, Sirius...)"
                           Text="{Binding StarSearchText, Mode=TwoWay}"
                           TextChanged="OnStarSearchTextChanged"
                           PlaceholderColor="{DynamicResource ColorTextMuted}"
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Search"
                           VerticalOptions="Center" />
                </Border>

                <!-- Star results -->
                <CollectionView IsVisible="{Binding IsStarListVisible}"
                                ItemsSource="{Binding FilteredStars}"
                                SelectionMode="Single"
                                SelectionChanged="OnStarSelected"
                                MaximumHeightRequest="200">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{DynamicResource ColorSurface}"
                                    Stroke="{DynamicResource ColorBorder}"
                                    StrokeThickness="1"
                                    Padding="12,10"
                                    StrokeShape="RoundRectangle 8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding DisplayName}"
                                           TextColor="{DynamicResource ColorTextPrimary}"
                                           FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding VisualMagnitude, StringFormat='mag {0:F1}'}"
                                           TextColor="{DynamicResource ColorTextSecondary}"
                                           FontSize="11"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
                    <ui:AppButton Grid.Column="0"
                                  Text="Build Star Hop Map"
                                  Variant="Primary"
                                  Command="{Binding BuildMapCommand}" />

                    <ui:AppButton Grid.Column="1"
                                  Text="Show RA/Dec Deltas"
                                  Variant="Secondary"
                                  Command="{Binding ShowDeltasCommand}" />
                </Grid>

                <!-- Results -->
                <Border IsVisible="{Binding HasResult}"
                        BackgroundColor="{DynamicResource ColorSurface}"
                        Stroke="{DynamicResource ColorBorder}"
                        StrokeThickness="1"
                        Padding="16"
                        StrokeShape="RoundRectangle 12"
                        Margin="0,8,0,16">
                    <Label Text="{Binding ResultText}"
                           TextColor="{DynamicResource ColorTextPrimary}"
                           FontSize="13"
                           FontFamily="Consolas"
                           LineBreakMode="WordWrap" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
