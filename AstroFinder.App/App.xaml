<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AstroFinder.App"
             xmlns:converters="clr-namespace:AstroFinder.App.Converters"
             xmlns:design="clr-namespace:AstroApps.Maui.UIKit.Resources.Styles;assembly=AstroApps.Maui.UIKit"
             x:Class="AstroFinder.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <design:DesignSystem />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:InvertBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
